---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Packman - Multi-Language Pac-Man',
  description = 'Pac-Man implemented in 5 programming languages: Python, JavaScript, TypeScript, Java, and C++',
  ogImage = '/og-default.png',
} = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/play', label: 'Play' },
  { href: '/compare', label: 'Compare' },
  { href: '/architecture', label: 'Architecture' },
  { href: '/languages', label: 'Languages' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="flex flex-col min-h-screen bg-pacman-black">
    <!-- Navigation -->
    <header class="border-b-2 border-wall-blue">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 group">
            <span class="text-pacman-yellow text-2xl animate-chomp">&#9679;</span>
            <span class="font-heading text-pacman-yellow text-sm sm:text-base tracking-wider">
              PACKMAN
            </span>
          </a>

          <!-- Desktop Nav Links -->
          <div class="hidden md:flex items-center gap-1">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class:list={[
                  'px-3 py-2 text-sm font-heading tracking-wide transition-colors duration-200',
                  currentPath === link.href
                    ? 'text-pacman-yellow'
                    : 'text-gray-400 hover:text-pacman-yellow',
                ]}
              >
                {link.label}
              </a>
            ))}
          </div>

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden text-pacman-yellow p-2"
            aria-label="Toggle menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"
              />
            </svg>
          </button>
        </div>

        <!-- Mobile Nav Links -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'block px-3 py-2 text-sm font-heading tracking-wide transition-colors duration-200',
                currentPath === link.href
                  ? 'text-pacman-yellow'
                  : 'text-gray-400 hover:text-pacman-yellow',
              ]}
            >
              {link.label}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t-2 border-wall-blue mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-gray-500 text-xs font-heading">
            PACKMAN &copy; {new Date().getFullYear()}
          </p>
          <p class="text-gray-600 text-xs">
            Pac-Man in 5 languages: Python, JavaScript, TypeScript, Java, C++
          </p>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-ghost-red inline-block"></span>
            <span class="w-2 h-2 rounded-full bg-ghost-pink inline-block"></span>
            <span class="w-2 h-2 rounded-full bg-ghost-cyan inline-block"></span>
            <span class="w-2 h-2 rounded-full bg-ghost-magenta inline-block"></span>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile menu toggle script -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
