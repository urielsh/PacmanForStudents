# .clang-tidy — static analysis configuration for code quality.
#
# Run manually:   clang-tidy -p build *.cpp
# Or integrate with CMake:  cmake -DCMAKE_CXX_CLANG_TIDY=clang-tidy ..
#
# Educational note: clang-tidy is a linter/static-analyzer for C/C++ that
# catches bugs, style issues, and modernization opportunities at compile time.
# Comparable to ESLint (JS/TS), Pylint/Ruff (Python), or SpotBugs (Java).

Checks: >
  -*,
  bugprone-*,
  modernize-use-override,
  modernize-use-nullptr,
  modernize-use-auto,
  modernize-loop-convert,
  readability-identifier-naming,
  readability-braces-around-statements,
  performance-unnecessary-copy-initialization,
  performance-for-range-copy

WarningsAsErrors: ''

CheckOptions:
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: camelBack
  - key: readability-identifier-naming.VariableCase
    value: camelBack
  - key: readability-identifier-naming.ConstantCase
    value: UPPER_CASE
